  "home": {
    "title": "C-Voices: LLM Core Value Evaluation System",
    "subtitle": "C-Voices: LLM Value Evaluation System",
    "description1": "C-Voices is a value evaluation and visual analysis platform for large language models, built upon the 12 dimensions of Chinese Socialist Core Values (Prosperity, Democracy, Civility, Harmony, Freedom, Equality, Justice, Rule of Law, Patriotism, Dedication, Integrity, and Friendship) to establish a unified evaluation framework for systematic and quantitative analysis of model value orientations across various scenarios.",
    "description2": "The platform empowers researchers and developers to comprehensively understand model value expression characteristics at national, social, and individual levels through two evaluation modes: open-ended Q&A and value-based choice questions, enabling risk identification and facilitating model alignment and optimization.",
    "openQuestionMode": "Open-ended Mode: Randomly selects evaluation questions and performs 12-dimension scoring based on model-generated responses.",
    "choiceQuestionMode": "Choice-based Mode: Presents A/B options (Support/Oppose) for value dilemmas and calculates model support rates across each dimension.",
    "conclusion": "Through these two evaluation modes, C-Voices enables you to quickly gain insights into different models' value orientations and potential risks at national, social, and individual levels.",
    "featureModulesTitle": "Feature Modules",
    "featureModulesSubtitle": "Choose your desired feature module to begin your intelligent evaluation journey",
    "textEvaluation": "Text Evaluation",
    "modelEvaluation": "Model Evaluation", 
    "historyRecords": "History Records",
    "learnMore": "Learn More"
  },
  "textScoring": {
    "title": "Text Value 12-Dimension Scoring",
    "subtitle": "Analyze value orientation of any input text and output 12-dimension scoring results",
    "description1": "This feature performs value analysis on individual text segments, utilizing a unified trained scoring model to quantitatively evaluate text content across 12 dimensions: Prosperity, Democracy, Civility, Harmony, Freedom, Equality, Justice, Rule of Law, Patriotism, Dedication, Integrity, and Friendship.",
    "description2": "Ideal for rapid value orientation detection and risk analysis of model-generated content, human-written text, or dialogue fragments.",
    "description3": "Supports pasting model outputs, dialogue content, or any text fragments, automatically generating radar charts and dimension scores.",
